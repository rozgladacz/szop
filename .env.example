# SZOP - Kreator armii — przykładowy plik konfiguracji
#
# Skopiuj jako ".env" w katalogu gdzie uruchamiasz docker-compose.yml.
# Wszystkie zmienne mają rozsądne wartości domyślne — plik .env jest opcjonalny.
# Aplikacja sama wygeneruje SECRET_KEY i UPDATE_WEBHOOK_TOKEN przy pierwszym starcie
# (zapisuje je do data/.secret_key i data/.webhook_token).

# ---------------------------------------------------------------------------
# Podstawowa konfiguracja
# ---------------------------------------------------------------------------

# Klucz sesji — jeśli nie ustawiony, aplikacja wygeneruje go automatycznie
# i zapisze do data/.secret_key. Ustaw explicite jeśli chcesz przenosić sesje
# między instancjami lub mieć deterministyczny klucz.
# SECRET_KEY=

# URL bazy danych SQLAlchemy. SQLite (domyślne) jest wystarczający dla jednej instancji.
# DB_URL=sqlite:///./data/szop.db

# Tryb debugowania — NIGDY nie ustawiaj na true w produkcji.
# DEBUG=false

# ---------------------------------------------------------------------------
# Bezpieczeństwo
# ---------------------------------------------------------------------------

# Lista dozwolonych hostów oddzielona przecinkami (np. "opr.tailnet.ts.net,localhost").
# Wartość "*" (domyślna) wyłącza sprawdzanie — zawęź gdy chcesz ochrony przed
# atakami Host-header injection.
# TRUSTED_HOSTS=*

# Ustaw na "true" gdy aplikacja jest serwowana przez HTTPS (np. tailscale serve).
# Sprawia że ciasteczko sesji ma flagę Secure — nie wysyłane przez HTTP.
# SESSION_HTTPS_ONLY=false

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------

# Liczba dni przechowywania automatycznych kopii zapasowych.
# BACKUP_RETENTION_DAYS=14

# Godzina lokalnego czasu uruchamiania codziennego backupu (0-23).
# BACKUP_HOUR=3

# Katalog backupów (wewnątrz wolumenu data/).
# BACKUP_DIR=/app/data/backups

# ---------------------------------------------------------------------------
# Aktualizacja przez panel admina
# ---------------------------------------------------------------------------

# Token autoryzujący webhook aktualizacji (POST /admin/update/webhook).
# Jeśli nie ustawiony, aplikacja wygeneruje go i zapisze do data/.webhook_token.
# Odczytaj go stamtąd lub ustaw tutaj.
# UPDATE_WEBHOOK_TOKEN=

# Plik docker-compose używany do aktualizacji usługi.
# Ustaw bezwzględną ścieżkę do pliku na hoście (mount /var/run/docker.sock jest wymagany).
# UPDATE_COMPOSE_FILE=/srv/szop/docker-compose.yml

# Nazwa usługi w docker-compose do zaktualizowania.
# UPDATE_SERVICE_NAME=szop-app

# ---------------------------------------------------------------------------
# Referencje Git (używane przez webhook do aktualizacji git-only)
# ---------------------------------------------------------------------------

# UPDATE_REPO_URL=https://github.com/rozgladacz/szop
# UPDATE_BRANCH=main
# UPDATE_REF=
